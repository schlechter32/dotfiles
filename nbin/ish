#!/usr/bin/env bash

set -euo pipefail

SSH_CONFIG="${HOME}/dotfiles_ikr/.ssh/config"

usage() {
    echo "Usage: ish [ssh options] host [command ...]" >&2
    exit 1
}

have_cmd() {
    command -v "$1" >/dev/null 2>&1
}

trim() {
    local value="$1"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    printf '%s\n' "$value"
}

match_host_pattern() {
    local host="$1"
    local pattern="$2"
    [[ "$host" == $pattern ]]
}

sshpass_entry_for_host() {
    local host="$1"
    local current_patterns=()
    local line rest entry pattern

    [[ -r "$SSH_CONFIG" ]] || return 1

    while IFS= read -r line; do
        if [[ $line =~ ^[[:space:]]*Host[[:space:]]+ ]]; then
            rest="${line#*[Hh]ost }"
            read -r -a current_patterns <<<"$rest"
            continue
        fi

        if [[ $line =~ ^[[:space:]]*(Match|Include)[[:space:]]+ ]]; then
            current_patterns=()
            continue
        fi

        if [[ $line =~ ^[[:space:]]*#sshpass[[:space:]]+(.+)$ ]]; then
            entry="$(trim "${BASH_REMATCH[1]}")"
            for pattern in "${current_patterns[@]}"; do
                if match_host_pattern "$host" "$pattern"; then
                    printf '%s\n' "$entry"
                    return 0
                fi
            done
        fi
    done <"$SSH_CONFIG"

    return 1
}

ssh_g_value() {
    local config="$1"
    local key="$2"

    awk -v wanted="$key" '
        $1 == wanted {
            $1 = ""
            sub(/^ /, "")
            print
            exit
        }
    ' <<<"$config"
}

first_proxyjump_host() {
    local proxyjump="$1"
    proxyjump="${proxyjump%%,*}"
    proxyjump="${proxyjump%% *}"
    printf '%s\n' "$proxyjump"
}

pass_value_for_entry() {
    local entry="$1"
    local value=""

    if [[ "$entry" == */* ]]; then
        pass show "$entry" 2>/dev/null | head -n 1
        return
    fi

    value="$(pass show "ssh/$entry" 2>/dev/null | head -n 1)" || true
    if [[ -n "$value" ]]; then
        printf '%s\n' "$value"
        return
    fi

    pass show "$entry" 2>/dev/null | head -n 1
}

ssh_args=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --)
            ssh_args+=("$1")
            shift
            break
            ;;
        -p|-l|-i|-L|-D|-o|-F|-J|-W|-b|-c|-E|-e|-I|-m|-O|-Q|-R|-S|-w)
            [[ $# -ge 2 ]] || usage
            ssh_args+=("$1" "$2")
            shift 2
            ;;
        -[46AaCfGgKkMNnqsTtVvXxYy])
            ssh_args+=("$1")
            shift
            ;;
        -*)
            ssh_args+=("$1")
            shift
            ;;
        *)
            break
            ;;
    esac
done

[[ $# -ge 1 ]] || usage

target_host="$1"
shift
remote_args=("$@")

if ! have_cmd ssh; then
    echo "ssh not found" >&2
    exit 1
fi

if ! have_cmd sshpass; then
    exec ssh "${ssh_args[@]}" "$target_host" "${remote_args[@]}"
fi

if ! have_cmd pass; then
    exec ssh "${ssh_args[@]}" "$target_host" "${remote_args[@]}"
fi

effective_config="$(ssh -G "${ssh_args[@]}" "$target_host" 2>/dev/null)" || {
    exec ssh "${ssh_args[@]}" "$target_host" "${remote_args[@]}"
}

proxy_jump="$(ssh_g_value "$effective_config" "proxyjump")"
proxy_command="$(ssh_g_value "$effective_config" "proxycommand")"

target_pass_entry="$(sshpass_entry_for_host "$target_host" || true)"

if [[ -z "$target_pass_entry" ]]; then
    exec ssh "${ssh_args[@]}" "$target_host" "${remote_args[@]}"
fi

target_password="$(pass_value_for_entry "$target_pass_entry")" || {
    exec ssh "${ssh_args[@]}" "$target_host" "${remote_args[@]}"
}

proxy_host=""
proxy_pass_entry=""

if [[ -n "$proxy_jump" && "$proxy_jump" != "none" ]]; then
    proxy_host="$(first_proxyjump_host "$proxy_jump")"
    proxy_pass_entry="$(sshpass_entry_for_host "$proxy_host" || true)"
elif [[ "$proxy_command" =~ ssh[[:space:]]+([^[:space:]]+)[[:space:]]+-W[[:space:]] ]]; then
    proxy_host="${BASH_REMATCH[1]}"
    proxy_pass_entry="$(sshpass_entry_for_host "$proxy_host" || true)"
fi

if [[ -z "$proxy_pass_entry" ]]; then
    exec 3<<<"$target_password"
    exec sshpass -d 3 ssh "${ssh_args[@]}" "$target_host" "${remote_args[@]}"
fi

proxy_password="$(pass_value_for_entry "$proxy_pass_entry")" || {
    exec 3<<<"$target_password"
    exec sshpass -d 3 ssh "${ssh_args[@]}" "$target_host" "${remote_args[@]}"
}

exec 3<<<"$proxy_password"
exec 4<<<"$target_password"
exec sshpass -d 4 ssh \
    "${ssh_args[@]}" \
    -o "ProxyCommand=sshpass -d 3 ssh ${proxy_host} -W %h:%p" \
    "$target_host" \
    "${remote_args[@]}"
