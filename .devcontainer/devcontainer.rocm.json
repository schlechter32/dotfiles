{
  "name": "dotfiles-rocm-${localWorkspaceFolderBasename}",
  "image": "ghcr.io/schlechter32/devenv:latest",
  "remoteUser": "dev",
  "containerUser": "dev",
  "updateRemoteUserUID": true,
  "workspaceFolder": "/workspace",
  "runArgs": [
    "--hostname=${localWorkspaceFolderBasename}",
    "--device=/dev/dri",
    "--device=/dev/kfd",
    "--group-add=keep-groups",
    "--volume=/opt/rocm:/opt/rocm:ro",
    "--add-host=host.containers.internal:host-gateway"
  ],
  "containerEnv": {
    "NPM_CONFIG_PREFIX": "/home/dev/.local",
    "UV_CACHE_DIR": "/home/dev/.cache/uv",
    "UV_LINK_MODE": "copy",
    "ROCM_PATH": "/opt/rocm",
    "HIP_PATH": "/opt/rocm",
    "HSA_PATH": "/opt/rocm",
    "LD_LIBRARY_PATH": "/opt/rocm/lib:/opt/rocm/hip/lib:/run/opengl-driver/lib"
  },
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/dev/.claude,type=bind",
    "source=${localEnv:HOME}/.claude.json,target=/home/dev/.claude.json,type=bind",
    "source=${localEnv:HOME}/.codex,target=/home/dev/.codex,type=bind",
    "source=${localEnv:HOME}/.config/opencode,target=/home/dev/.config/opencode,type=bind",
    "source=${localEnv:HOME}/.local/share/opencode,target=/home/dev/.local/share/opencode,type=bind",
    "source=${localEnv:HOME}/.cache/uv,target=/home/dev/.cache/uv,type=bind",
    "source=${localEnv:HOME}/nixos-config,target=/home/dev/nixos-config,type=bind"
  ],
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  }
}
